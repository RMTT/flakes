# direnv config for services deployment

export PATH="$(pwd)/.bin:$PATH"

echo "Services deployment utilities:"
echo ""
echo "  install     - Install current chart"
echo "  upgrade     - Upgrade current chart"
echo "  uninstall   - Uninstall current chart"
echo "  status      - Show current chart status"
echo ""

echo "DNS deployment utilities:"
echo ""
echo "  cf-record-ids - List Cloudflare DNS record IDs"
echo ""

echo "SOPS related utilities:"
echo ""
echo "  sops-updatekeys - Update SOPS keys for all encrypted files"
echo ""
